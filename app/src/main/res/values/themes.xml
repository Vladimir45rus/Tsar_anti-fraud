<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Базовая тема приложения -->
    <style name="Theme.TsarShield" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Цвета -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/black</item>
        
        <!-- <item name="colorBackground">@color/white</item> -->
        <!-- <item name="colorOnBackground">@color/black</item> -->
        
        <item name="colorError">@color/red_500</item>
        <item name="colorOnError">@color/white</item>
        
        <!-- Статус бар -->
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        
        <!-- Навигационная панель -->
        <item name="android:navigationBarColor" tools:targetApi="o">?attr/colorPrimary</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o">true</item>
        
        <!-- Формы -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.TsarShield.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.TsarShield.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.TsarShield.Large</item>
        
        <!-- Текстовые стили -->
        <item name="textAppearanceHeadline1">@style/TextAppearance.TsarShield.Headline1</item>
        <item name="textAppearanceHeadline2">@style/TextAppearance.TsarShield.Headline2</item>
        <item name="textAppearanceHeadline3">@style/TextAppearance.TsarShield.Headline3</item>
        <item name="textAppearanceHeadline4">@style/TextAppearance.TsarShield.Headline4</item>
        <item name="textAppearanceHeadline5">@style/TextAppearance.TsarShield.Headline5</item>
        <item name="textAppearanceHeadline6">@style/TextAppearance.TsarShield.Headline6</item>
        <item name="textAppearanceSubtitle1">@style/TextAppearance.TsarShield.Subtitle1</item>
        <item name="textAppearanceSubtitle2">@style/TextAppearance.TsarShield.Subtitle2</item>
        <item name="textAppearanceBody1">@style/TextAppearance.TsarShield.Body1</item>
        <item name="textAppearanceBody2">@style/TextAppearance.TsarShield.Body2</item>
        <item name="textAppearanceCaption">@style/TextAppearance.TsarShield.Caption</item>
        <item name="textAppearanceButton">@style/TextAppearance.TsarShield.Button</item>
        <item name="textAppearanceOverline">@style/TextAppearance.TsarShield.Overline</item>
    </style>

    <!-- Формы -->
    <style name="ShapeAppearance.TsarShield.Small" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">4dp</item>
    </style>
    
    <style name="ShapeAppearance.TsarShield.Medium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>
    
    <style name="ShapeAppearance.TsarShield.Large" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <!-- Текстовые стили -->
    <style name="TextAppearance.TsarShield.Headline1" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:textSize">96sp</item>
        <item name="android:letterSpacing">-0.015</item>
    </style>
    
    <style name="TextAppearance.TsarShield.Headline2" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:textSize">60sp</item>
        <item name="android:letterSpacing">-0.005</item>
    </style>
    
    <style name="TextAppearance.TsarShield.Headline3" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:textSize">48sp</item>
    </style>
    
    <style name="TextAppearance.TsarShield.Headline4" parent="TextAppearance.Material3.TitleLarge">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:textSize">34sp</item>
    </style>
    
    <style name="TextAppearance.TsarShield.Headline5" parent="TextAppearance.Material3.TitleMedium">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:textSize">24sp</item>
    </style>
    
    <style name="TextAppearance.TsarShield.Headline6" parent="TextAppearance.Material3.TitleSmall">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:textSize">20sp</item>
    </style>
    
    <style name="TextAppearance.TsarShield.Subtitle1" parent="TextAppearance.Material3.BodyLarge">
        <item name="fontFamily">sans-serif</item>
        <item name="android:textSize">16sp</item>
    </style>
    
    <style name="TextAppearance.TsarShield.Subtitle2" parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:textSize">14sp</item>
    </style>
    
    <style name="TextAppearance.TsarShield.Body1" parent="TextAppearance.Material3.BodyLarge">
        <item name="fontFamily">sans-serif</item>
        <item name="android:textSize">16sp</item>
    </style>
    
    <style name="TextAppearance.TsarShield.Body2" parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">sans-serif</item>
        <item name="android:textSize">14sp</item>
    </style>
    
    <style name="TextAppearance.TsarShield.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="fontFamily">sans-serif</item>
        <item name="android:textSize">12sp</item>
    </style>
    
    <style name="TextAppearance.TsarShield.Button" parent="TextAppearance.Material3.LabelLarge">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
    </style>
    
    <style name="TextAppearance.TsarShield.Overline" parent="TextAppearance.Material3.LabelSmall">
        <item name="fontFamily">sans-serif-medium</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textSize">10sp</item>
    </style>

    <!-- Темная тема -->
    <style name="Theme.TsarShield.Dark" parent="Theme.TsarShield">
        <item name="colorPrimary">@color/purple_200</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/black</item>
        
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_200</item>
        <item name="colorOnSecondary">@color/black</item>
        
        <item name="colorSurface">@color/gray_900</item>
        <item name="colorOnSurface">@color/white</item>
        
        <!-- <item name="colorBackground">@color/gray_900</item> -->
        <!-- <item name="colorOnBackground">@color/white</item> -->
        
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        
        <item name="android:navigationBarColor" tools:targetApi="o">?attr/colorPrimary</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o">false</item>
    </style>

</resources>